# Root .dockerignore — for the frontend (Vite) image build
# Only apps/web/, docker/frontend/, and the workspace manifests
# are needed. Everything else stays out of the build context.

# Git
.git
.gitignore

# Env files — baked values come via build-args
.env
.env.*
apps/web/.env
apps/web/.env.*

# Don't send backend into the frontend build context
apps/api
backend

# node_modules — installed fresh inside the container
node_modules
apps/web/node_modules

# Build artefacts
apps/web/build
.turbo

# Testing / tooling
coverage
*.log
npm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# Docs / infra files not needed for the React build
README.md
docker/nginx
