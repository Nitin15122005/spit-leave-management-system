# ============================================================
# SPIT Leave Management System — .gitignore
# ============================================================

# ────────────────────────────────────────
# Dependencies (NEVER commit these)
# ────────────────────────────────────────
node_modules/
apps/web/node_modules/
apps/api/node_modules/
# Legacy paths (pre-Turborepo)
backend/node_modules/

# ────────────────────────────────────────
# Build outputs
# ────────────────────────────────────────
apps/web/build/
apps/api/dist/
# Legacy
/build
backend/dist/

# ────────────────────────────────────────
# Turborepo cache
# ────────────────────────────────────────
.turbo/

# ────────────────────────────────────────
# Environment / Secrets (NEVER commit)
# ────────────────────────────────────────
.env
.env.local
.env.*.local
apps/web/.env
apps/web/.env.local
apps/web/.env.*.local
apps/api/.env
apps/api/.env.local
# Legacy
backend/.env
backend/.env.local

# ────────────────────────────────────────
# Uploads (runtime data, not code)
# ────────────────────────────────────────
apps/api/uploads/
backend/uploads/

# ────────────────────────────────────────
# Prisma generated client
# ────────────────────────────────────────
apps/api/node_modules/.prisma/

# ────────────────────────────────────────
# Logs
# ────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ────────────────────────────────────────
# OS / Editor
# ────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ────────────────────────────────────────
# Testing
# ────────────────────────────────────────
coverage/
apps/web/coverage/
apps/api/coverage/

# ────────────────────────────────────────
# Misc
# ────────────────────────────────────────
/.pnp
.pnp.js