# ============================================================
# SPIT Leave Management System — .gitignore
# ============================================================

# ────────────────────────────────────────
# Dependencies (NEVER commit these)
# ────────────────────────────────────────
node_modules/
backend/node_modules/
backend/.prisma/
backend/dist/          # compiled TypeScript output

# ────────────────────────────────────────
# Environment / Secrets (NEVER commit)
# ────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
backend/.env.local

# ────────────────────────────────────────
# Build outputs
# ────────────────────────────────────────
/build                 # CRA production build
backend/dist/          # TypeScript compiled output

# ────────────────────────────────────────
# Uploads (runtime data, not code)
# ────────────────────────────────────────
backend/uploads/

# ────────────────────────────────────────
# Logs
# ────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ────────────────────────────────────────
# OS / Editor
# ────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ────────────────────────────────────────
# Testing
# ────────────────────────────────────────
/coverage

# ────────────────────────────────────────
# Misc CRA / tooling
# ────────────────────────────────────────
/.pnp
.pnp.js