// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  student
  teacher
  hod
  dean
  coordinator
}

enum LeaveStatus {
  pending_teacher
  pending_hod
  pending_dean
  approved
  rejected
  completed
}

// ============================================
// MODELS
// ============================================

model User {
  id         Int      @id @default(autoincrement())
  uid        String   @unique
  name       String
  email      String?  @unique
  password   String
  role       Role
  department String?
  class      String?  // TE, SE, BE, etc. (for students)
  mobile     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  leaveApplications LeaveApplication[] @relation("StudentLeaves")

  @@map("users")
}

model Subject {
  id   Int    @id @default(autoincrement())
  code String @unique
  name String

  // Relations
  leaveSubjects LeaveSubject[]

  @@map("subjects")
}

model LeaveApplication {
  id            Int         @id @default(autoincrement())
  studentId     Int
  student       User        @relation("StudentLeaves", fields: [studentId], references: [id])

  // Cached student info (for display without joins)
  studentName   String
  studentUid    String
  studentClass  String
  studentMobile String

  // Event info
  eventName          String
  organizedBy        String
  venue              String
  eventLink          String?
  proofLink          String?
  eventDurationFrom  DateTime
  eventDurationTo    DateTime
  leaveDatesFrom     DateTime
  leaveDatesTo       DateTime
  semester           Int

  // Totals
  totalTheory Int @default(0)
  totalLab    Int @default(0)

  // Workflow
  status              LeaveStatus @default(pending_teacher)
  teacherComment      String?
  hodComment          String?
  deanComment         String?
  coordinatorComment  String?
  attendanceMarked    Boolean     @default(false)
  declaration         Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subjects LeaveSubject[]

  @@map("leave_applications")
}

model LeaveSubject {
  id              Int              @id @default(autoincrement())
  leaveId         Int
  leave           LeaveApplication @relation(fields: [leaveId], references: [id], onDelete: Cascade)
  subjectId       Int
  subject         Subject          @relation(fields: [subjectId], references: [id])

  subjectCode     String
  subjectName     String
  theoryCount     Int              @default(0)
  labCount        Int              @default(0)

  // Relations
  classes LeaveClass[]

  @@map("leave_subjects")
}

model LeaveClass {
  id             Int          @id @default(autoincrement())
  leaveSubjectId Int
  leaveSubject   LeaveSubject @relation(fields: [leaveSubjectId], references: [id], onDelete: Cascade)

  date    DateTime
  timing  String
  type    String   // "theory" | "lab"
  batch   String?  // for lab classes

  @@map("leave_classes")
}
