{
  "name": "spit-leave-management",
  "version": "1.0.0",
  "packageManager": "npm@11.5.1",
  "engines": {
    "node": ">=20"
  },
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev":         "turbo dev",
    "build":       "turbo build",
    "lint":        "turbo lint",
    "test":        "turbo test",
    "start":       "npm run db:generate && turbo dev",
    "setup":       "npm install && npm run db:generate && npm run db:migrate",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:migrate":  "npm run db:migrate --workspace=apps/api",
    "db:seed":     "npm run db:seed --workspace=apps/api",
    "db:studio":   "npm run db:studio --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^2.5.3"
  }
}